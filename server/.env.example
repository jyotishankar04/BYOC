NODE_ENV=development
PORT=4000

# Database — Prisma reads DATABASE_URL directly; the POSTGRES_* vars are for Docker Compose only
DATABASE_URL=postgresql://byoc_user:byoc_password@localhost:5432/byoc_db

# PostgreSQL (used by Docker Compose to initialise the container)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=byoc_db
POSTGRES_USER=byoc_user
POSTGRES_PASSWORD=byoc_password

# Redis — set REDIS_URL for managed Redis (Upstash, etc.) or use host/port for self-hosted
REDIS_URL=
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Mail — set MAIL_PROVIDER=resend and RESEND_API_KEY for production; use smtp+Mailhog for local dev
MAIL_PROVIDER=smtp
MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_SECURE=false
MAIL_FROM=no-reply@byoc.local
RESEND_API_KEY=re_xxx

# Google OAuth (https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# 32-byte hex string used to encrypt stored provider credentials
CRED_ENCRYPTION_KEY=

# S3 webhook shared secret
WEBHOOK_SECRET=

# Logging
LOG_LEVEL=info
LOG_PRETTY=false

# JWT secrets — must be at least 32 chars; generate with: openssl rand -hex 32
JWT_SECRET=replace-with-a-long-random-secret
JWT_ACCESS_SECRET=replace-with-a-long-random-secret
JWT_REFRESH_SECRET=replace-with-a-long-random-secret

# Cookie domain — set to your apex domain in production (e.g. .bringbucket.app)
COOKIE_DOMAIN=

# Frontend
FRONTEND_URL=http://localhost:3000

# Polar.sh billing (https://polar.sh/dashboard)
POLAR_ACCESS_TOKEN=polar_oat_xxx
POLAR_SERVER=sandbox
POLAR_SUCCESS_URL=http://localhost:3000/app/billing
POLAR_RETURN_URL=http://localhost:3000/app/billing
POLAR_WEBHOOK_SECRET=polar_whs_xxx

# Polar product IDs (one per plan/interval)
POLAR_PRO_PRODUCT_ID=
POLAR_PRO_6M_PRODUCT_ID=
POLAR_TEAM_PRODUCT_ID=
POLAR_TEAM_6M_PRODUCT_ID=

# Platform storage — for profile avatars (S3, R2, MinIO, etc.)
# Set PLATFORM_S3_PUBLIC_URL if the bucket is publicly accessible (stores permanent URL)
# Otherwise a presigned GET URL is generated on each profile load
PLATFORM_S3_PROVIDER=S3
PLATFORM_S3_ACCESS_KEY_ID=
PLATFORM_S3_SECRET_ACCESS_KEY=
PLATFORM_S3_BUCKET=
PLATFORM_S3_REGION=us-east-1
PLATFORM_S3_ENDPOINT=
PLATFORM_S3_PUBLIC_URL=
