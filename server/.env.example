NODE_ENV=development
PORT=3000

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=byoc_db
POSTGRES_USER=byoc_user
POSTGRES_PASSWORD=byoc_password

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Mailhog
MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_SECURE=false
MAIL_FROM=no-reply@byoc.local

# Google OAuth (https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# 32-byte hex string used to encrypt stored provider credentials
CRED_ENCRYPTION_KEY=

# S3 webhook shared secret
WEBHOOK_SECRET=

# Logging
LOG_LEVEL=info
LOG_PRETTY=false
JWT_ACCESS_SECRET=replace-with-a-long-random-secret
JWT_REFRESH_SECRET=replace-with-a-long-random-secret

# Frontend
FRONTEND_URL=http://localhost:3000

# Polar.sh billing (https://polar.sh/dashboard)
POLAR_ACCESS_TOKEN=polar_oat_xxx
POLAR_SERVER=sandbox
POLAR_SUCCESS_URL=http://localhost:3000/app/billing
POLAR_RETURN_URL=http://localhost:3000/app/billing
POLAR_WEBHOOK_SECRET=polar_whs_xxx

# Polar product IDs (one per plan/interval)
POLAR_PRO_PRODUCT_ID=
POLAR_PRO_6M_PRODUCT_ID=
POLAR_TEAM_PRODUCT_ID=
POLAR_TEAM_6M_PRODUCT_ID=
