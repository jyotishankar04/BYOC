# ── Database (Neon or any external Postgres) ─────────────────────────────────
DATABASE_URL=

# ── App ───────────────────────────────────────────────────────────────────────
LOG_LEVEL=info
LOG_PRETTY=false
FRONTEND_URL=https://yourdomain.com
COOKIE_DOMAIN=.yourdomain.com

# ── Auth secrets (generate with: openssl rand -base64 48) ────────────────────
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_SECRET=

# ── Credential encryption (generate with: openssl rand -hex 32) ──────────────
CRED_ENCRYPTION_KEY=

# ── Email ─────────────────────────────────────────────────────────────────────
MAIL_PROVIDER=resend
RESEND_API_KEY=
MAIL_FROM=no-reply@yourdomain.com

# ── Google OAuth (optional) ──────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Polar billing (optional) ─────────────────────────────────────────────────
POLAR_ACCESS_TOKEN=
POLAR_SERVER=production
POLAR_SUCCESS_URL=https://yourdomain.com/app/billing
POLAR_RETURN_URL=https://yourdomain.com/app/billing
POLAR_WEBHOOK_SECRET=
POLAR_PRO_PRODUCT_ID=
POLAR_TEAM_PRODUCT_ID=
POLAR_PRO_6M_PRODUCT_ID=
POLAR_TEAM_6M_PRODUCT_ID=

# ── Storage webhook (optional) ───────────────────────────────────────────────
WEBHOOK_SECRET=
